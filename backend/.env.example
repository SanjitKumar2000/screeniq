# Backend environment — copy to .env and fill in.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres)
DATABASE_URL=postgres://screeniq:screeniq@localhost:5432/screeniq

# CORS — Next.js dev origin
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# AI provider — pick ONE of the blocks below.
# All providers use the OpenAI-compatible Chat Completions API, so the only
# things that change are base URL, key, and model id.
# ─────────────────────────────────────────────────────────────────────────────

# Option 1: Local Ollama (default — free, runs offline, no API key)
AI_PROVIDER=ollama
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3:latest

# Option 2: OpenAI (paid; requires billing at platform.openai.com)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Option 3: Ollama Cloud (free tier; hosted models, requires key from ollama.com)
# AI_PROVIDER=ollama
# OPENAI_API_KEY=<your-ollama-cloud-key>
# OPENAI_BASE_URL=https://ollama.com/v1
# OPENAI_MODEL=gpt-oss:120b-cloud
