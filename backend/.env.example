# Backend environment — copy to .env and fill in.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres)
DATABASE_URL=postgres://screeniq:screeniq@localhost:5432/screeniq

# CORS — Next.js dev origin
CORS_ALLOWED_ORIGINS=http://localhost:3000

# AI provider
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
